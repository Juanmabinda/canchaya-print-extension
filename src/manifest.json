{
  "manifest_version": 3,
  "name": "Mi Tienda Print",
  "description": "Imprime tickets, comandas y etiquetas desde Mi Tienda POS sin instalar agente externo. Soporta impresoras térmicas USB y LAN (cualquiera instalada en Windows/Mac).",
  "version": "0.0.1",
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "action": {
    "default_title": "Mi Tienda Print",
    "default_popup": "popup.html"
  },
  "permissions": [
    "printing",
    "printerProvider",
    "storage"
  ],
  "host_permissions": [
    "https://mitiendapos.com.ar/*",
    "https://staging.mitiendapos.com.ar/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "https://mitiendapos.com.ar/*",
        "https://staging.mitiendapos.com.ar/*"
      ],
      "js": ["content.js"],
      "run_at": "document_start",
      "world": "ISOLATED"
    }
  ]
}
