{
  "manifest_version": 3,
  "name": "Mi Tienda Print",
  "description": "Imprime tickets, comandas y etiquetas desde Mi Tienda POS sin instalar agente externo. Soporta impresoras t\u00e9rmicas USB y LAN (cualquiera instalada en Windows/Mac).",
  "version": "0.0.1",
  "key": "",
  "action": {
    "default_title": "Mi Tienda Print",
    "default_popup": "popup.html"
  },
  "permissions": [
    "nativeMessaging",
    "storage",
    "tabs"
  ],
  "host_permissions": [
    "https://mitiendapos.com.ar/*",
    "https://staging.mitiendapos.com.ar/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "https://mitiendapos.com.ar/*",
        "https://staging.mitiendapos.com.ar/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_start",
      "world": "ISOLATED"
    }
  ]
}