<?xml version="1.0" encoding="UTF-8"?>
<Wix xmlns="http://schemas.microsoft.com/wix/2006/wi">
  <Product Id="41B78F23-6E17-4DE4-B43D-166DFD9AD7E1"
           Name="Mi Tienda Print Agent"
           Language="1033"
           Version="0.10.14.0"
           Manufacturer="Mi Tienda POS"
           UpgradeCode="3a5e1f02-7c44-4d97-9d3b-3a0c1e9f5b40">

    <Package InstallerVersion="200"
             Compressed="yes"
             InstallScope="perUser"
             Description="Mi Tienda Print Native Messaging Host" />

    <!-- Upgrade explicito (mas portable que MajorUpgrade en wixl): el viejo
         MSI con mismo UpgradeCode se desinstala automaticamente cuando se
         instala uno nuevo con version mayor. -->
    <Upgrade Id="3a5e1f02-7c44-4d97-9d3b-3a0c1e9f5b40">
      <UpgradeVersion Minimum="0.0.0"
                      Maximum="0.10.14.0"
                      IncludeMinimum="yes"
                      IncludeMaximum="no"
                      Property="OLDERVERSIONBEINGUPGRADED" />
    </Upgrade>
    <InstallExecuteSequence>
      <RemoveExistingProducts After="InstallInitialize" />
      <!-- FixManifest se schedulea aca tambien (wixl solo tolera un
           InstallExecuteSequence por Product). After="InstallFiles" para que
           el .vbs ya este copiado al disco. Condition: solo se saltea en
           uninstall puro (REMOVE="ALL"). En install + reinstall corre. -->
      <Custom Action="FixManifest" After="InstallFiles">NOT REMOVE</Custom>
    </InstallExecuteSequence>

    <Media Id="1" Cabinet="agent.cab" EmbedCab="yes" />

    <Directory Id="TARGETDIR" Name="SourceDir">
      <Directory Id="LocalAppDataFolder">
        <Directory Id="INSTALLDIR" Name="MiTiendaPrint">

          <Component Id="cmpBinary"
                     Guid="2EF3A2B3-5BC8-4F21-B62B-692E3CFE3F72"
                     Win64="yes">
            <RegistryValue Root="HKCU"
                           Key="Software\Mi Tienda POS\MiTiendaPrint"
                           Name="Installed"
                           Type="integer"
                           Value="1"
                           KeyPath="yes" />
            <File Id="filBinary"
                  Name="mitienda-print.exe"
                  Source="/Users/andress/juanma/canchaya-print-extension/installers/build/msi-mitienda/mitienda-print.exe" />
            <RemoveFolder Id="rmInstallDir" On="uninstall" />
          </Component>

          <Component Id="cmpManifest"
                     Guid="D1C4D6BD-C411-4752-BA31-067742A8CB73"
                     Win64="yes">
            <RegistryValue Root="HKCU"
                           Key="Software\Mi Tienda POS\MiTiendaPrint"
                           Name="ManifestInstalled"
                           Type="integer"
                           Value="1"
                           KeyPath="yes" />
            <File Id="filManifest"
                  Name="ar.mitiendapos.print.json"
                  Source="/Users/andress/juanma/canchaya-print-extension/installers/build/msi-mitienda/ar.mitiendapos.print.json" />
            <!-- Script de fixup que reescribe el JSON con path absoluto en
                 postinstall (Chrome on Win requiere absoluto). VBScript en
                 lugar de PowerShell para compatibilidad con Win 7 (que viene
                 con PowerShell 2.0 sin ConvertTo-Json). -->
            <File Id="filFixManifestVBS"
                  Name="fix_manifest.vbs"
                  Source="/Users/andress/juanma/canchaya-print-extension/installers/build/msi-mitienda/fix_manifest.vbs" />
          </Component>

          <!-- Tres entries de registry, uno por navegador. KeyPath en el
               propio RegistryValue para que wix lo trackee. -->
          <Component Id="cmpRegChrome"
                     Guid="09F0555C-70D5-4A82-8852-95E56E03DA5E"
                     Win64="yes">
            <RegistryKey Root="HKCU"
                         Key="Software\Google\Chrome\NativeMessagingHosts\ar.mitiendapos.print">
              <RegistryValue Type="string"
                             Value="[INSTALLDIR]ar.mitiendapos.print.json"
                             KeyPath="yes" />
            </RegistryKey>
          </Component>

          <Component Id="cmpRegEdge"
                     Guid="B8AAA4D9-0B37-43D7-91CB-E76F611E4908"
                     Win64="yes">
            <RegistryKey Root="HKCU"
                         Key="Software\Microsoft\Edge\NativeMessagingHosts\ar.mitiendapos.print">
              <RegistryValue Type="string"
                             Value="[INSTALLDIR]ar.mitiendapos.print.json"
                             KeyPath="yes" />
            </RegistryKey>
          </Component>

          <Component Id="cmpRegBrave"
                     Guid="22FBD9B3-BC7F-4C65-9BFC-C945EF0F95ED"
                     Win64="yes">
            <RegistryKey Root="HKCU"
                         Key="Software\BraveSoftware\Brave-Browser\NativeMessagingHosts\ar.mitiendapos.print">
              <RegistryValue Type="string"
                             Value="[INSTALLDIR]ar.mitiendapos.print.json"
                             KeyPath="yes" />
            </RegistryKey>
          </Component>

        </Directory>
      </Directory>
    </Directory>

    <Feature Id="Main" Title="Mi Tienda Print Agent" Level="1">
      <ComponentRef Id="cmpBinary" />
      <ComponentRef Id="cmpManifest" />
      <ComponentRef Id="cmpRegChrome" />
      <ComponentRef Id="cmpRegEdge" />
      <ComponentRef Id="cmpRegBrave" />
    </Feature>

    <!-- CustomAction: ejecuta fix_manifest.vbs al final del install para
         reescribir el JSON con el path absoluto del binario. Sin esto,
         Chrome en Windows tira "Specified native messaging host not found".
         VBScript con cscript.exe — estandar Win XP+ sin requerir PowerShell. -->
    <Property Id="CSCRIPTEXE" Value="cscript.exe" />
    <CustomAction Id="FixManifest"
                  Property="CSCRIPTEXE"
                  ExeCommand='//nologo "[INSTALLDIR]fix_manifest.vbs" mitienda'
                  Execute="deferred"
                  Impersonate="yes"
                  Return="ignore" />

  </Product>
</Wix>
